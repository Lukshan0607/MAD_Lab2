<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:padding="24dp"
    tools:context=".AnalyticsActivity">

    <!-- Top Navigation Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rounded_button_bg"
            android:contentDescription="@string/back_button_description"
            android:src="@drawable/ic_back"
            app:tint="@color/secondary_700" />

        <!-- Screen Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/analytics"
            android:textAlignment="center"
            android:textColor="@color/on_background"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/statusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/low_badge_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="@string/low"
            android:textColor="@color/secondary_700"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Content Scroll View -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/checkout_your_recent_performance"
                android:textColor="@color/on_background"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Weekly Report Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/weekly_report"
                android:textColor="@color/on_background"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Weekly Mood Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="7"
                android:rowCount="2">

                <!-- Sad Face Icons and Days of the Week -->
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:contentDescription="Very sad face"
                    app:tint="@color/tertiary_700" />
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:contentDescription="Sad face"
                    app:tint="@color/tertiary_700" />
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:contentDescription="Neutral face"
                    app:tint="@color/tertiary_700" />

            </GridLayout>

            <!-- Monthly Report Section -->
            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                app:srcCompat="@drawable/emoji" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/monthly_report"
                android:textColor="@color/on_background"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Placeholder for Graph -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/chart"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Icon Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bottom_bar_bg"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/home_icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Happy face icon"
            android:padding="8dp"
            android:src="@drawable/ic_happy_face"
            app:tint="@color/on_surface" />

        <ImageButton
            android:id="@+id/analytics_icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/selected_icon_bg"
            android:contentDescription="Heart icon"
            android:padding="8dp"
            android:src="@drawable/ic_heart"
            app:tint="@color/on_primary" />

        <ImageButton
            android:id="@+id/profile_icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Robot icon"
            android:padding="8dp"
            android:src="@drawable/ic_robot"
            app:tint="@color/on_surface" />

        <ImageButton
            android:id="@+id/resources_icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Lamp icon"
            android:padding="8dp"
            android:src="@drawable/ic_lamp"
            app:tint="@color/on_surface" />

        <ImageButton
            android:id="@+id/settings_icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Flag icon"
            android:padding="8dp"
            android:src="@drawable/ic_flag"
            app:tint="@color/on_surface" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
